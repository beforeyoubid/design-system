{
  "name": "@beforeyoubid/design-system",
  "version": "1.0.0-alpha.6",
  "description": "BYB design system — Tailwind CSS + Base UI components for the BYB public website",
  "author": "Before You Buy",
  "license": "ISC",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "tailwind.config.ts",
    "globals.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tailwind.config": "./tailwind.config.ts",
    "./globals.css": "./globals.css"
  },
  "scripts": {
    "build": "tsup",
    "build-and-publish": "npm run build && npm publish --access public",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "check-tokens": "node scripts/check-tokens.js",
    "test": "jest"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^6",
    "@typescript-eslint/parser": "^6",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^4",
    "eslint-plugin-storybook": "^10.3.6",
    "next": "^14",
    "playwright": "^1.59.1",
    "storybook": "^10.3.6",
    "tailwindcss": "^3",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-alpha.4",
    "clsx": "^2",
    "tailwind-merge": "^2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beforeyoubid/design-system.git"
  },
  "bugs": {
    "url": "https://github.com/beforeyoubid/design-system/issues"
  },
  "homepage": "https://github.com/beforeyoubid/design-system#readme"
}
